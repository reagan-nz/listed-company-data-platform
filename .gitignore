# 隔离批次 harvest 根目录（phase2 smoke / phase3 batch 等 live 写入）
outputs/harvest/cninfo_c_class/phase*/
# Transient harvest resume markers (any output root)
outputs/harvest/**/run_status.json
outputs/harvest/**/company_harvest_status.csv

# ── Runtime Artifact Ignore Boundary（autonomous live / harvest bulk）──
# 保留：outputs/validation/**/reports/ · summary MD · evidence ledgers · QA closure
# Harvest runtime（含 fuller_market 等嵌套批次目录）
outputs/harvest/**/raw/
outputs/harvest/**/normalized/
outputs/harvest/**/quality/**
outputs/harvest/**/live_snapshots/
# harvest status rebuild backup：默认忽略，避免 dirty；需保留时复制到 outputs/validation evidence package
outputs/harvest/**/company_harvest_status.csv.bak_pre_offline_rebuild_*
# Validation runtime bulk（不忽略 reports/ 与顶层 evidence MD/CSV）
outputs/validation/**/raw_metadata/
outputs/validation/**/live_snapshots/
outputs/validation/**/quality/*.json
# Validation runtime noise（run meta / test guards）
outputs/validation/**/run_meta.json
outputs/validation/**/_production_guard/
outputs/validation/**/_erad_test_guard.txt
# Local-only portrait generated outputs
outputs/portrait/

# C-class 逐行 validation 大表（脚本可重跑；保留 *_summary.md 与小表）
outputs/validation/cninfo_c_class_phase*_harvest_dryrun_report.csv
outputs/validation/cninfo_c_class_phase*_harvest_output_root_dryrun_report.csv
outputs/validation/cninfo_c_class_phase*_live_harvest_report.csv
