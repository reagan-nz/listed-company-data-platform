{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cninfo-era-c.local/schemas/b_class/b_document_citation_span.schema.json",
  "title": "b_document_citation_span",
  "description": "CNINFO B-class citation span for RAG provenance (design draft). Not verified; not a DB migration.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "citation_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    }
  },
  "properties": {
    "citation_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_id": {
      "type": "string"
    },
    "page_no": {
      "type": "integer",
      "minimum": 1
    },
    "span_start": {
      "type": "integer",
      "minimum": 0
    },
    "span_end": {
      "type": "integer",
      "minimum": 0
    },
    "quote_text": {
      "type": "string"
    },
    "citation_confidence": {
      "$ref": "#/definitions/citation_confidence"
    }
  },
  "required": ["citation_id", "document_id"]
}
