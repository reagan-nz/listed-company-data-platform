{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cninfo-era-c.local/schemas/b_class/b_document_chunk.schema.json",
  "title": "b_document_chunk",
  "description": "CNINFO B-class RAG chunk unit (design draft). Not verified; not a DB migration.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "quality_flag": {
      "type": "string",
      "enum": [
        "scanned_pdf_candidate",
        "table_heavy",
        "image_heavy",
        "title_mismatch",
        "period_mismatch",
        "duplicate_candidate",
        "low_text_density",
        "parse_failed"
      ]
    }
  },
  "properties": {
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "section_id": {
      "type": "string"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 0
    },
    "text": {
      "type": "string"
    },
    "token_count_candidate": {
      "type": "integer",
      "minimum": 0
    },
    "page_start": {
      "type": "integer",
      "minimum": 1
    },
    "page_end": {
      "type": "integer",
      "minimum": 1
    },
    "chunk_strategy": {
      "type": "string",
      "description": "e.g. fixed_token, section_boundary."
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/quality_flag"
      },
      "uniqueItems": true
    }
  },
  "required": ["chunk_id", "document_id", "chunk_index", "text"]
}
