{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cninfo-era-c.local/schemas/d_class/d_company_metric_daily.schema.json",
  "title": "d_company_metric_daily",
  "description": "CNINFO D-class company x trade_date metric row (narrow table). Primary: margin_trading. Optional ETL from block_trade.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "source_status": {
      "type": "string",
      "enum": [
        "candidate",
        "testing",
        "testing_stable_sample",
        "testing_partial",
        "blocked",
        "deprecated"
      ]
    },
    "field_confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    }
  },
  "properties": {
    "metric_id": {
      "type": "string",
      "description": "Logical primary key per metric row."
    },
    "source_id": {
      "type": "string"
    },
    "company_code": {
      "type": "string"
    },
    "company_name": {
      "type": "string"
    },
    "trade_date": {
      "type": "string",
      "format": "date"
    },
    "metric_name": {
      "type": "string",
      "description": "Standard metric name (e.g. financing_balance_yuan)."
    },
    "metric_value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "raw_field": {
      "type": "string",
      "description": "Source raw field name (e.g. F001N)."
    },
    "raw_record_json": {
      "type": "object",
      "description": "Full original CNINFO record object."
    },
    "raw_record_hash": {
      "type": "string",
      "minLength": 1
    },
    "query_params": {
      "type": "object"
    },
    "fetch_time": {
      "type": "string",
      "format": "date-time"
    },
    "source_status": {
      "$ref": "#/definitions/source_status"
    },
    "field_confidence": {
      "$ref": "#/definitions/field_confidence"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "metric_id",
    "source_id",
    "company_code",
    "trade_date",
    "metric_name",
    "metric_value",
    "raw_record_json",
    "raw_record_hash"
  ]
}
